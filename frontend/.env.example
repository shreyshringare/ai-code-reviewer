# ── SnapCode Frontend — Environment Variables ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Required for ReviewOrchestrator (multi-agent review) and /api/chat streaming.
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for user authentication (login / signup / session management).
# Find these in: Supabase Dashboard → Project Settings → API
# Use the ANON key here (not the service role key — that stays on the backend).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Express Backend ───────────────────────────────────────────────────────────
# URL of the Express API server (backend/).
# All AI review calls (POST /review, POST /github-review, GET /review-job/:id)
# are made to this URL from the frontend.
# Development default: http://localhost:8000
# Production: your deployed backend URL (e.g. https://api.snapcode.app)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of this Next.js app. Used for internal SSR API calls.
NEXT_PUBLIC_APP_URL=http://localhost:3000
