# ── SnapCode Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
#
# TIP: In production, use Doppler instead of a .env file:
#   doppler setup           (run once, links this directory to your Doppler project)
#   npm run start:doppler   (injects secrets at runtime — no .env file needed)
#   npm run dev:doppler     (same, for local development)
#
# Never commit .env to git.

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Required. Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required. Find these in your Supabase project → Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Required. Found in Supabase → Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── GitHub ────────────────────────────────────────────────────────────────────
# Recommended — without this, GitHub API calls are limited to 60 req/hour.
# Create a classic PAT at https://github.com/settings/tokens (no scopes needed).
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for Redis caching (POST /review) and BullMQ job queue (/github-review).
# For local dev: install Redis (https://redis.io/docs/install) and leave defaults.
# For production: use Redis Cloud (https://redis.com/try-free/) or Upstash.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=          # set this if your Redis instance requires a password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# CORS origin — set to your deployed frontend URL in production.
FRONTEND_URL=http://localhost:3000

# ── Observability ─────────────────────────────────────────────────────────────
# Optional. Get DSN from sentry.io → New Project → Node.js.
# Sentry is silently disabled when this is unset.
SENTRY_DSN=

# Optional. Controls Pino log verbosity: trace | debug | info | warn | error
LOG_LEVEL=info
